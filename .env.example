# ============================================================================
# Provider Mais Fibra — exemplo de variáveis de ambiente.
# Copie para .env e preencha com valores REAIS. Nunca faça commit do .env.
# ============================================================================

# Banco Postgres (provisionado pelo Replit)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Chave do painel admin (mínimo 24 caracteres em produção).
# Gere com: openssl rand -base64 32
ADMIN_SECRET=troque-isto-por-uma-string-aleatoria-de-32-chars

# Salt para hash do IP em logs anti-fraude (não é secret crítico, mas evite default)
INTEREST_IP_SALT=troque-isto-tambem
CONTACT_TRAP_SECRET=outro-segredo-aleatorio

# Porta da API (definida pelo Replit em produção)
PORT=3000
