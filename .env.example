# ============================================================================
# Provider Mais Fibra — variáveis de ambiente (exemplo).
# Copie este arquivo para .env e preencha com valores REAIS.
# NUNCA faça commit do .env — ele já está coberto pelo .gitignore.
#
# Geração de segredos seguros:
#   openssl rand -base64 48
# ============================================================================

# ----------------------------------------------------------------------------
# Banco de dados (Supabase Postgres)
# ----------------------------------------------------------------------------
# URL do pooler (porta 6543) — usada pela API em runtime.
SUPABASE_DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres

# URL direta (porta 5432) — usada por migrations e scripts (drizzle-kit).
SUPABASE_DATABASE_URL_DIRECT=postgres://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres

# Senha do banco (sem URL-encode) — usada por scripts auxiliares.
SUPABASE_DB_PASSWORD=<senha-do-banco>

# Identificadores do projeto Supabase.
SUPABASE_PROJECT_REF=<project-ref>
SUPABASE_REGION=<aws-region>

# URL pública e chave de service-role do Supabase (Storage / Auth).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SECRET_KEY=<service-role-key>

# Compatibilidade com bibliotecas legadas que usam DATABASE_URL.
# Pode apontar para o mesmo valor de SUPABASE_DATABASE_URL.
DATABASE_URL=${SUPABASE_DATABASE_URL}

# ----------------------------------------------------------------------------
# Painel admin / segurança
# ----------------------------------------------------------------------------
# Segredo HMAC para assinar JWTs do painel admin.
# Mínimo 32 caracteres em produção (16 em dev).
JWT_SECRET=troque-isto-por-uma-string-aleatoria-de-no-minimo-32-chars

# Credenciais do primeiro admin (criadas apenas no primeiro boot,
# se a tabela admin_users estiver vazia). Senha mínima de 8 caracteres.
ADMIN_EMAIL=admin@providerfibra.com.br
ADMIN_PASSWORD=troque-esta-senha-no-primeiro-login

# Salts e segredos auxiliares (anti-fraude / honeypots).
INTEREST_IP_SALT=troque-isto-tambem
IP_HASH_SALT=outro-salt-aleatorio
CONTACT_TRAP_SECRET=outro-segredo-aleatorio

# ----------------------------------------------------------------------------
# Servidor
# ----------------------------------------------------------------------------
# Porta da API (em produção a Hostinger normalmente injeta isto).
PORT=3000

# development | production
NODE_ENV=production

# trace | debug | info | warn | error  (default: info em prod)
LOG_LEVEL=info

# URL pública do site (sem barra no final). Usada em e-mails, sitemap, SEO.
PUBLIC_BASE_URL=https://www.providerfibra.com.br
VITE_SITE_URL=https://www.providerfibra.com.br

# Link absoluto para o painel admin (usado nos e-mails de digest).
ADMIN_DASHBOARD_URL=https://www.providerfibra.com.br/admin

# Número padrão de WhatsApp para CTAs (formato internacional, só dígitos).
DEFAULT_WHATSAPP_NUMBER=5511999999999

# ----------------------------------------------------------------------------
# Object Storage (Supabase Storage / GCS)
# ----------------------------------------------------------------------------
PRIVATE_OBJECT_DIR=/uploads/private
PUBLIC_OBJECT_SEARCH_PATHS=/uploads/public

# ----------------------------------------------------------------------------
# E-mail (SMTP) — usado pelos digests e notificações
# ----------------------------------------------------------------------------
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=no-reply@providerfibra.com.br
SMTP_PASS=<senha-smtp>
SMTP_FROM="Provider Mais Fibra <no-reply@providerfibra.com.br>"

# ----------------------------------------------------------------------------
# Backfill (one-off scripts) — opcional, valores default são seguros
# ----------------------------------------------------------------------------
# BACKFILL_DRY_RUN=true
# BACKFILL_USE_USER_AGENT=true
# BACKFILL_BURST_MIN_ROWS=5
# BACKFILL_BURST_WINDOW_SECONDS=60
