# ============================================================================
# Provider Mais Fibra — exemplo de variáveis de ambiente.
# Copie para .env e preencha com valores REAIS. Nunca faça commit do .env.
# ============================================================================

# Banco Postgres (provisionado pelo Replit)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Segredo HMAC para assinar JWTs do painel admin (mínimo 32 caracteres
# em produção; mínimo 16 em desenvolvimento). Gere com: openssl rand -base64 48
JWT_SECRET=troque-isto-por-uma-string-aleatoria-de-no-minimo-32-chars

# E-mail e senha do primeiro admin (usados apenas no primeiro boot, se
# admin_users estiver vazio). Senha precisa ter no mínimo 8 caracteres.
ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=troque-esta-senha-no-primeiro-login

# Salt para hash do IP em logs anti-fraude (não é secret crítico, mas evite default)
INTEREST_IP_SALT=troque-isto-tambem
CONTACT_TRAP_SECRET=outro-segredo-aleatorio

# Porta da API (definida pelo Replit em produção)
PORT=3000
